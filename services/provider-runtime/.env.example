HOST=127.0.0.1
PORT=3200
CONTROL_PLANE_BASE_URL=http://127.0.0.1:3100
PROVIDER_RUNTIME_API_KEY=csk_provider_runtime_local_seed_secret_000000

# Private connector mode is optional. Leave PROVIDER_RUNTIME_API_KEY in place for
# marketplace provider-node execution, or set the following values to run the
# runtime as a buyer-scoped private connector.
# PRIVATE_CONNECTOR_ORGANIZATION_ID=
# PRIVATE_CONNECTOR_ENVIRONMENT=development
# PRIVATE_CONNECTOR_ID=
# PRIVATE_CONNECTOR_MODE=cluster
# PRIVATE_CONNECTOR_FORWARD_BASE_URL=http://127.0.0.1:3301
# PRIVATE_CONNECTOR_UPSTREAM_API_KEY=
# PRIVATE_CONNECTOR_ORG_API_KEY=
# PRIVATE_CONNECTOR_RUNTIME_VERSION=local
# PRIVATE_CONNECTOR_HEARTBEAT_INTERVAL_MS=30000
